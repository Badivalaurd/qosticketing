# ============================================================
# QoS Ticketing — Configuration réseau (à remplir par le DSI)
# Copier ce fichier en network.env dans :
#   %APPDATA%\QoSTicketing\data\network.env
#
# Ce fichier est lu par le launcher AVANT le démarrage de Django.
# Aucune recompilation nécessaire pour changer l'adresse du serveur.
# ============================================================

# Adresse IP ou nom DNS du serveur PostgreSQL sur le réseau interne
DB_HOST=192.168.1.100

# Nom de la base de données
DB_NAME=qos_ticketing

# Identifiants PostgreSQL (lecture/écriture)
DB_USER=qos_user
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE

# Port PostgreSQL (5432 par défaut)
DB_PORT=5432

# Domaine email autorisé pour l'inscription (@orange.com par défaut)
ALLOWED_EMAIL_DOMAIN=@orange.com

# Durée de validité du cache local de connexion (en jours, 90 par défaut)
LOCAL_AUTH_CACHE_DAYS=90

# Clé secrète Django (DOIT être identique sur tous les postes)
SECRET_KEY=REMPLACER_PAR_UNE_CLE_SECRETE_LONGUE_ET_ALEATOIRE
